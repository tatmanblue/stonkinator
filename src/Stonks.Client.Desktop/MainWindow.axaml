<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sp="clr-namespace:ScottPlot.Avalonia;assembly=ScottPlot.Avalonia"
        x:Class="Stonks.Client.Desktop.MainWindow"
        x:CompileBindings="False"
        Title="Stonks — Stock Analysis"
        Width="1200" Height="700"
        MinWidth="800" MinHeight="500">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Input row -->
        <Border Grid.Row="0" Padding="12">
            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                <TextBlock VerticalAlignment="Center" Text="Ticker:" />
                <TextBox Width="80" Text="{Binding Ticker}" />
                <TextBlock VerticalAlignment="Center" Text="From:" />
                <DatePicker SelectedDate="{Binding StartDate}" />
                <TextBlock VerticalAlignment="Center" Text="To:" />
                <DatePicker SelectedDate="{Binding EndDate}" />
                <Button Content="Analyze" Command="{Binding AnalyzeCommand}" />
                <TextBlock VerticalAlignment="Center"
                           Text="Loading..."
                           IsVisible="{Binding IsLoading}" />
            </StackPanel>
        </Border>

        <!-- Content row -->
        <Grid Grid.Row="1" ColumnDefinitions="*,*">
            <sp:AvaPlot x:Name="AvaPlot" Grid.Column="0" Margin="4" />
            <ScrollViewer x:Name="AnalysisScroll" Grid.Column="1" Margin="4">
                <TextBlock Text="{Binding AnalysisText}"
                           TextWrapping="Wrap"
                           Padding="8"
                           FontFamily="Consolas,Courier New,monospace" />
            </ScrollViewer>
        </Grid>

        <!-- Disclaimer row -->
        <Border Grid.Row="2" Background="#FFF3CD" Padding="8">
            <TextBlock Text="For educational purposes only. Not financial advice."
                       HorizontalAlignment="Center"
                       FontStyle="Italic" />
        </Border>

    </Grid>
</Window>
