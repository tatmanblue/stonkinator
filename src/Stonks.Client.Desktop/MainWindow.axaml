<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:Stonks.Client.Desktop.Views"
        x:Class="Stonks.Client.Desktop.MainWindow"
        x:CompileBindings="False"
        Title="Stonks — Stock Analysis"
        Width="1200" Height="700"
        MinWidth="800" MinHeight="500">

    <Grid RowDefinitions="*,Auto">

        <TabControl Grid.Row="0" SelectedIndex="{Binding SelectedTabIndex}">

            <TabItem Header="Dashboard">
                <views:DashboardView DataContext="{Binding Dashboard}" />
            </TabItem>

            <TabItem Header="Search / Analyze">
                <views:SearchAnalyzeView DataContext="{Binding SearchAnalyze}" />
            </TabItem>

        </TabControl>

        <!-- Disclaimer bar — always visible outside the tabs -->
        <Border Grid.Row="1" Background="#FFF3CD" Padding="8">
            <TextBlock Text="For educational purposes only. Not financial advice."
                       HorizontalAlignment="Center"
                       FontStyle="Italic" />
        </Border>

    </Grid>

</Window>
