<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sp="clr-namespace:ScottPlot.Avalonia;assembly=ScottPlot.Avalonia"
             x:Class="Stonks.Client.Desktop.Views.SearchAnalyzeView"
             x:CompileBindings="False">

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- Error banner (visible only when HasError is true) -->
        <Border Grid.Row="0"
                Background="#F8D7DA"
                BorderBrush="#F5C6CB"
                BorderThickness="1"
                CornerRadius="4"
                Padding="10,8"
                Margin="8,8,8,0"
                IsVisible="{Binding HasError}">
            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="#721C24"
                       TextWrapping="Wrap" />
        </Border>

        <!-- Input row -->
        <Border Grid.Row="1" Padding="12">
            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                <TextBlock VerticalAlignment="Center" Text="Ticker:" />
                <TextBox Width="80" Text="{Binding Ticker}" />
                <TextBlock VerticalAlignment="Center" Text="From:" />
                <DatePicker SelectedDate="{Binding StartDate}" />
                <TextBlock VerticalAlignment="Center" Text="To:" />
                <DatePicker SelectedDate="{Binding EndDate}" />
                <Button Content="Analyze" Command="{Binding AnalyzeCommand}" />
                <TextBlock VerticalAlignment="Center"
                           Text="Loading..."
                           IsVisible="{Binding IsLoading}" />
            </StackPanel>
        </Border>

        <!-- Content row: chart left, analysis text right -->
        <Grid Grid.Row="2" ColumnDefinitions="*,*">
            <sp:AvaPlot x:Name="AvaPlot" Grid.Column="0" Margin="4" />
            <ScrollViewer x:Name="AnalysisScroll" Grid.Column="1" Margin="4">
                <TextBlock Text="{Binding AnalysisText}"
                           TextWrapping="Wrap"
                           Padding="8"
                           FontFamily="Consolas,Courier New,monospace" />
            </ScrollViewer>
        </Grid>

    </Grid>

</UserControl>
